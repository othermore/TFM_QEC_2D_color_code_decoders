% Boson table
\newcommand{\condensed}{\bullet}
\newcommand{\confined}{\bm{\times}}
\newcommand{\electric}{\blacksquare}
\newcommand{\magnetic}{\blacktriangle}
\newcommand{\colorone}[1]{{\color{orange} #1}}
\newcommand{\colortwo}[1]{{\color{SkyBlue} #1}}
\newcommand{\coloredelectric}[1]{%
    \IfEqCase{#1}{%
        {1}{\colorone{\electric}}%
        {2}{\colortwo{\electric}}%
    }[\electric]
}
\newcommand{\coloredmagnetic}[1]{%
    \IfEqCase{#1}{%
        {1}{\colortwo{\magnetic}}%
        {2}{\colorone{\magnetic}}%
    }[\magnetic]%
}
\newcommand{\selectsymbol}[5][]{%
    \IfEq{#2}{#4}%
    {\IfEq{#3}{#5}{\condensed}{\coloredelectric{#1}}}%
    {\IfEq{#3}{#5}{\coloredmagnetic{#1}}{\confined}}%
}
\newcommand{\bosontabletemp}[9]{\begin{array}{c|c|c}#1&#2&#3 \\ \hline #4&#5&#6 \\ \hline #7&#8&#9\end{array}}
\newcommand{\bosontable}{\bosontabletemp{\rx}{\gx}{\bx}{\ry}{\gy}{\by}{\rz}{\gz}{\bz}}
\newcommand{\bosontablepartial}[3][]{\bosontabletemp%
    {\selectsymbol[#1]{r}{x}{#2}{#3}}%
    {\selectsymbol[#1]{g}{x}{#2}{#3}}%
    {\selectsymbol[#1]{b}{x}{#2}{#3}}%
    {\selectsymbol[#1]{r}{y}{#2}{#3}}%
    {\selectsymbol[#1]{g}{y}{#2}{#3}}%
    {\selectsymbol[#1]{b}{y}{#2}{#3}}%
    {\selectsymbol[#1]{r}{z}{#2}{#3}}%
    {\selectsymbol[#1]{g}{z}{#2}{#3}}%
    {\selectsymbol[#1]{b}{z}{#2}{#3}}%
}
\newcommand{\bosontableST}[7][]{
    \bosontablepartial[#6]{#2}{#3} \xleftrightarrow{#1} \bosontablepartial[#7]{#4}{#5}
}
